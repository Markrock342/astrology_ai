// HoraSard — AI Horoscope Web App
// Prisma schema — Milestone 1 (Phase 1 scope only)
// Docs: https://www.prisma.io/docs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum AccessLevel {
  FREE
  PRO
}

enum PackageType {
  FREE
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum ActivationSource {
  SYSTEM_DEFAULT
  ADMIN_MANUAL
  PAYMENT
}

// Immutable ledger entry kinds. Balance only ever changes via a transaction row.
enum CreditTxnType {
  INITIAL_GRANT
  ADMIN_ADD
  ADMIN_DEDUCT
  AI_USAGE
  REFUND
  PACKAGE_RENEWAL
  PROMOTION
}

enum PromptType {
  SYSTEM
  PERSONA
  CATEGORY
  FORMAT
  KNOWLEDGE
}

enum AIProvider {
  GEMINI
  OPENAI
}

enum PlanScope {
  FREE
  PRO
  ALL
}

enum ReadingStatus {
  SUCCESS
  FAILED
  TIMEOUT
  /// Assistant reply accepted; AI still running in background.
  PENDING
}

// Chat thread mode. NATAL = natal chart (Free/Pro categories); TRANSIT = ดวงจร
// (Pro-only). Transit auto-calculation is gated until confirmed in Phase 1.
enum ConversationMode {
  NATAL
  TRANSIT
}

enum MessageRole {
  USER
  ASSISTANT
}

enum NatalChartStatus {
  PENDING
  READY
  FAILED
}

enum UsageStatus {
  SUCCESS
  FAILED
  TIMEOUT
  /// In-flight slot counted toward package quota until charge completes or release.
  RESERVED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ContentEntityType {
  APP_SETTING
  PROMPT_TEMPLATE
  KNOWLEDGE_DOC
  FAQ_ITEM
}

enum RevisionAction {
  DRAFT_SAVE
  PUBLISH
  RESTORE
}

enum AnnouncementTone {
  INFO
  WARNING
  PROMO
  DANGER
}

// ---------------------------------------------------------------------------
// Auth / Users
// ---------------------------------------------------------------------------

model User {
  id           String     @id @default(cuid())
  name         String?
  email        String     @unique
  // Profile photo URL (Google OAuth) or data URL (email upload).
  image        String?
  // Null when the user signs in only via an OAuth provider (e.g. Google).
  passwordHash String?
  role         Role       @default(USER)
  status       UserStatus @default(ACTIVE)
  emailVerifiedAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  birthProfile  BirthProfile?
  natalChart    NatalChart?
  creditWallet  CreditWallet?
  subscriptions UserSubscription[]
  creditTxns    CreditTransaction[]
  readings      HoroscopeReading[]
  conversations Conversation[]
  usageLogs     AIUsageLog[]
  payments      Payment[]
  pushSubscriptions PushSubscription[]

  // Records where this user acted as the reviewing/acting admin.
  adminCreditTxns  CreditTransaction[] @relation("CreditTxnAdmin")
  reviewedPayments Payment[]           @relation("PaymentReviewer")
  auditLogs        AdminAuditLog[]     @relation("AuditActor")
  contentRevisions ContentRevision[]   @relation("ContentRevisionAuthor")
  appSettingDrafts AppSetting[]        @relation("AppSettingDraftEditor")
  promptDrafts     PromptTemplate[]    @relation("PromptDraftEditor")
  knowledgeDrafts  KnowledgeDoc[]      @relation("KnowledgeDraftEditor")
  faqDrafts        FaqItem[]           @relation("FaqDraftEditor")

  // Auth.js OAuth support (optional — used only if Google login is enabled).
  accounts Account[]
  sessions Session[]

  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  @@index([role])
  @@index([status])
  @@map("users")
}

// Password reset tokens for the self-service "forgot password" flow. We store
// only a SHA-256 hash of the token (never the raw value), so a DB leak cannot be
// used to reset accounts. Tokens are single-use (usedAt) and short-lived.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

// Auth.js adapter tables (kept minimal; only needed for OAuth providers).
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model BirthProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  nickname       String?
  // Always stored as Gregorian (ค.ศ.) in UTC. The service converts a Buddhist
  // (พ.ศ.) year to Gregorian before persisting (rule: store UTC).
  birthDate      DateTime
  // Stored separately so an unknown birth time can be flagged explicitly.
  birthTime      String?
  birthTimeKnown Boolean  @default(true)
  gender         String?
  // Structured Thai location. birthLocation kept for legacy free-text.
  birthCountry   String   @default("ไทย")
  birthProvince  String?
  birthDistrict  String?
  birthLocation  String?
  additionalInfo String?
  consentVersion String?
  // Birth info may be edited only once more (0 = never edited, max 1). Enforced
  // in the birth-profile service, not just the DB.
  editCount      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  natalChart NatalChart?

  @@map("birth_profiles")
}

// Computed natal chart snapshot (engine stub → real calculation in Wave B+).
model NatalChart {
  id             String           @id @default(cuid())
  userId         String           @unique
  birthProfileId String           @unique
  status         NatalChartStatus @default(PENDING)
  chartJson      Json?
  note           String?
  computedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  birthProfile BirthProfile @relation(fields: [birthProfileId], references: [id], onDelete: Cascade)

  @@map("natal_charts")
}

// ---------------------------------------------------------------------------
// Catalog: categories, packages, prompts, AI configs
// ---------------------------------------------------------------------------

model HoroscopeCategory {
  id                 String      @id @default(cuid())
  slug               String      @unique
  nameTh             String
  nameEn             String?
  description        String?
  icon               String?
  accessLevel        AccessLevel @default(FREE)
  creditCost         Int         @default(1)
  enabled            Boolean     @default(true)
  sortOrder          Int         @default(0)
  // Suggested starter questions shown in the chat UI (array of Thai strings).
  suggestedQuestions Json?
  promptTemplateId   String?
  aiConfigId         String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  promptTemplate PromptTemplate?    @relation(fields: [promptTemplateId], references: [id])
  aiConfig       AIProviderConfig?  @relation(fields: [aiConfigId], references: [id])
  readings       HoroscopeReading[]
  conversations  Conversation[]
  knowledgeDocs  KnowledgeDoc[]

  @@index([enabled, sortOrder])
  @@map("horoscope_categories")
}

model Package {
  id           String      @id @default(cuid())
  code         String      @unique
  name         String
  type         PackageType @default(FREE)
  price        Int         @default(0)
  billingLabel String?
  creditQuota  Int         @default(0)
  dailyLimit   Int?
  monthlyLimit Int?
  enabled      Boolean     @default(true)
  description  String?
  /// Bullet points shown on the account/package comparison cards.
  features     String[]    @default([])
  /// Steps for manual Pro upgrade (read from the PRO package row).
  upgradeSteps String[]    @default([])
  /// When true, approving a payment only adds credits — no subscription change.
  creditOnly   Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  subscriptions UserSubscription[]

  @@map("packages")
}

model UserSubscription {
  id               String             @id @default(cuid())
  userId           String
  packageId        String
  status           SubscriptionStatus @default(ACTIVE)
  startsAt         DateTime           @default(now())
  // Null = indefinite (manual Pro without expiry).
  expiresAt        DateTime?
  activationSource ActivationSource   @default(SYSTEM_DEFAULT)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  package Package @relation(fields: [packageId], references: [id])

  @@index([userId, status])
  @@map("user_subscriptions")
}

// ---------------------------------------------------------------------------
// Credit wallet + immutable ledger
// ---------------------------------------------------------------------------

model CreditWallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  // Optimistic-lock counter: guards against concurrent deductions.
  version   Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_wallets")
}

model CreditTransaction {
  id               String        @id @default(cuid())
  userId           String
  // Signed delta applied to the wallet (negative = deduction).
  amount           Int
  type             CreditTxnType
  referenceType    String?
  referenceId      String?
  note             String?
  createdByAdminId String?
  createdAt        DateTime      @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin User? @relation("CreditTxnAdmin", fields: [createdByAdminId], references: [id])

  @@index([userId, createdAt])
  @@index([referenceType, referenceId])
  @@map("credit_transactions")
}

model PromptTemplate {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  type      PromptType
  content   String
  draftContent     String?
  draftUpdatedAt   DateTime?
  draftUpdatedById String?
  version   Int        @default(1)
  enabled   Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  draftUpdatedBy User? @relation("PromptDraftEditor", fields: [draftUpdatedById], references: [id])
  categories HoroscopeCategory[]
  aiConfigs  AIProviderConfig[]

  @@map("prompt_templates")
}

model AIProviderConfig {
  id               String     @id @default(cuid())
  provider         AIProvider @default(GEMINI)
  modelId          String
  displayName      String
  // Name of the env secret holding the API key — NEVER the key itself.
  secretReference  String
  enabled          Boolean    @default(true)
  temperature      Float      @default(0.7)
  maxOutputTokens  Int        @default(2048)
  timeoutMs        Int        @default(30000)
  fallbackConfigId String?
  planScope        PlanScope  @default(ALL)
  categoryId       String?
  promptTemplateId String?
  versionLabel     String?
  notes            String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  fallbackConfig AIProviderConfig?   @relation("AIConfigFallback", fields: [fallbackConfigId], references: [id])
  fallbackFor    AIProviderConfig[]  @relation("AIConfigFallback")
  promptTemplate PromptTemplate?     @relation(fields: [promptTemplateId], references: [id])
  categories     HoroscopeCategory[]

  @@index([enabled, planScope])
  @@map("ai_provider_configs")
}

// Admin-managed knowledge snippets injected into the system prompt (simple
// knowledge base — Phase 1). categoryId = null means "applies to all
// categories". If the corpus grows large, upgrade to chunked RAG (pgvector)
// reusing this table as the source of truth.
model KnowledgeDoc {
  id         String   @id @default(cuid())
  title      String
  content    String
  draftTitle   String?
  draftContent String?
  draftUpdatedAt   DateTime?
  draftUpdatedById String?
  categoryId String?
  enabled    Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  draftUpdatedBy User? @relation("KnowledgeDraftEditor", fields: [draftUpdatedById], references: [id])
  category HoroscopeCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([enabled, categoryId])
  @@map("knowledge_docs")
}

// ---------------------------------------------------------------------------
// Readings + usage logs
// ---------------------------------------------------------------------------

model HoroscopeReading {
  id                       String        @id @default(cuid())
  userId                   String
  // Idempotency guard: prevents duplicate readings + double charge on retry.
  idempotencyKey           String?
  // Frozen snapshot so later birth-profile edits never rewrite old readings.
  birthProfileSnapshotJson Json
  categoryId               String
  question                 String
  responseJson             Json?
  responseText             String?
  provider                 AIProvider?
  modelId                  String?
  promptTemplateId         String?
  promptVersion            Int?
  status                   ReadingStatus @default(SUCCESS)
  creditCost               Int           @default(0)
  createdAt                DateTime      @default(now())

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category HoroscopeCategory @relation(fields: [categoryId], references: [id])
  usageLog AIUsageLog?

  @@unique([userId, idempotencyKey])
  @@index([userId, createdAt])
  @@index([categoryId])
  @@map("horoscope_readings")
}

model AIUsageLog {
  id            String      @id @default(cuid())
  readingId     String?     @unique
  userId        String
  provider      AIProvider
  modelId       String
  status        UsageStatus
  inputUsage    Int?
  outputUsage   Int?
  estimatedCost Decimal?    @db.Decimal(12, 6)
  latencyMs     Int?
  errorCode     String?
  errorMessage  String?
  createdAt     DateTime    @default(now())

  reading HoroscopeReading? @relation(fields: [readingId], references: [id], onDelete: SetNull)
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status, createdAt])
  @@index([status])
  @@map("ai_usage_logs")
}

// ---------------------------------------------------------------------------
// Chat: conversations (threads) + messages
// ---------------------------------------------------------------------------

// A chat thread scoped to one category + mode. Credit is charged per assistant
// message (see Message.creditCost), not per thread.
model Conversation {
  id         String           @id @default(cuid())
  userId     String
  categoryId String
  mode       ConversationMode @default(NATAL)
  title      String?
  // Transit (ดวงจร) snapshot — Pro-only mode; populated when mode = TRANSIT.
  transitDate     DateTime?
  transitTime     String?
  transitCountry  String?
  transitProvince String?
  transitDistrict String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category HoroscopeCategory @relation(fields: [categoryId], references: [id])
  messages Message[]

  @@index([userId, createdAt])
  @@index([categoryId])
  @@map("conversations")
}

model Message {
  id               String        @id @default(cuid())
  conversationId   String
  role             MessageRole
  content          String
  // Idempotency guard for assistant answers: prevents duplicate messages +
  // double charge on retry/double-click (enforced by the message service).
  idempotencyKey   String?
  // Assistant-only metadata (null for USER messages).
  provider         AIProvider?
  modelId          String?
  promptTemplateId String?
  promptVersion    Int?
  creditCost       Int           @default(0)
  status           ReadingStatus @default(SUCCESS)
  inputUsage       Int?
  outputUsage      Int?
  createdAt        DateTime      @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, idempotencyKey])
  @@index([conversationId, createdAt])
  @@map("messages")
}

// ---------------------------------------------------------------------------
// Payments (manual, Phase 1) + audit + settings
// ---------------------------------------------------------------------------

model Payment {
  id                String        @id @default(cuid())
  userId            String
  amount            Int
  currency          String        @default("THB")
  paymentMethod     String?
  status            PaymentStatus @default(PENDING)
  paidAt            DateTime?
  proofUrl          String?
  reference         String?
  note              String?
  /// Package the user intended to purchase (e.g. PRO or CREDIT_TOPUP).
  packageCode       String?
  reviewedByAdminId String?
  reviewedAt        DateTime?
  /// When the post-review customer email was sent successfully.
  notifiedAt        DateTime?
  /// Last email delivery error (admin can retry manually).
  notifyError       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("PaymentReviewer", fields: [reviewedByAdminId], references: [id])

  @@index([userId, status])
  @@map("payments")
}

/** Web Push endpoints for admin PWA notifications (payment slips, etc.). */
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  entityType  String
  entityId    String?
  beforeJson  Json?
  afterJson   Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  admin User @relation("AuditActor", fields: [adminUserId], references: [id])

  @@index([entityType, entityId])
  @@index([adminUserId, createdAt])
  @@map("admin_audit_logs")
}

model AppSetting {
  key              String    @id
  valueJson        Json
  draftValueJson   Json?
  draftUpdatedAt   DateTime?
  draftUpdatedById String?
  updatedAt        DateTime  @updatedAt

  draftUpdatedBy User? @relation("AppSettingDraftEditor", fields: [draftUpdatedById], references: [id])

  @@map("app_settings")
}

model ContentRevision {
  id           String             @id @default(cuid())
  entityType   ContentEntityType
  entityId     String
  version      Int
  snapshotJson Json
  adminUserId  String
  action       RevisionAction
  note         String?
  createdAt    DateTime           @default(now())

  admin User @relation("ContentRevisionAuthor", fields: [adminUserId], references: [id])

  @@index([entityType, entityId, createdAt])
  @@map("content_revisions")
}

model SiteAnnouncement {
  id        String           @id @default(cuid())
  title     String
  message   String
  tone      AnnouncementTone @default(INFO)
  enabled   Boolean          @default(false)
  linkUrl   String?
  linkLabel String?
  startsAt  DateTime?
  endsAt    DateTime?
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([enabled, sortOrder])
  @@map("site_announcements")
}

model FaqItem {
  id               String   @id @default(cuid())
  question         String
  answer           String
  category         String   @default("general")
  enabled          Boolean  @default(true)
  sortOrder        Int      @default(0)
  draftQuestion    String?
  draftAnswer      String?
  draftUpdatedAt   DateTime?
  draftUpdatedById String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  draftUpdatedBy User? @relation("FaqDraftEditor", fields: [draftUpdatedById], references: [id])

  @@index([enabled, sortOrder])
  @@map("faq_items")
}
