# ---------------------------------------------------------------------------
# HoraSard — Environment variables
# Copy this file to `.env` and fill real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# PostgreSQL — Prisma ใช้ connection string นี้ (ไม่ใช่ publishable key)
# Local dev (Docker):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/horasard?schema=public"
# Supabase (direct — ใช้ตอน migrate + dev):
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[DATABASE_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/horasard?schema=public"

# ---- Supabase (project reference — optional client SDK) ----
# Publishable key ใช้กับ Supabase JS client เท่านั้น ห้ามใส่ใน DATABASE_URL
NEXT_PUBLIC_SUPABASE_URL="https://chtcblpydlwslddhxdbf.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key-here"

# ---- Auth.js (NextAuth v5) ----
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"
# Public base URL of the app.
AUTH_URL="http://localhost:3000"

# Optional Google OAuth (only if Google login is enabled in Phase 1).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---- AI providers ----
# API keys live ONLY here (server env). The database stores just the key NAME
# (secretReference), never the key value. Never expose these to the browser.
GEMINI_API_KEY=""
# Reserved for a future provider (adapter pattern). Leave empty in Phase 1.
OPENAI_API_KEY=""

# ---- App ----
NODE_ENV="development"
# Comma-separated admin emails auto-promoted on seed (optional convenience).
SEED_ADMIN_EMAIL="admin@horasard.local"
SEED_ADMIN_PASSWORD="ChangeMe123!"
