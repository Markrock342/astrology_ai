# ---------------------------------------------------------------------------
# HoraSard — Environment variables
# Copy this file to `.env` and fill real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# PostgreSQL — Prisma connection strings
# Local dev (Docker):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/horasard?schema=public"
#
# Supabase — use pooler on Vercel (IPv4); direct URL only for migrate/seed locally.
# DATABASE_URL (app runtime — transaction pooler, port 6543):
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL (migrations — session pooler, port 5432):
# DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/horasard?schema=public"
DIRECT_URL=""

# ---- Supabase (project reference — optional client SDK) ----
# Publishable key ใช้กับ Supabase JS client เท่านั้น ห้ามใส่ใน DATABASE_URL
NEXT_PUBLIC_SUPABASE_URL="https://chtcblpydlwslddhxdbf.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key-here"

# ---- Auth.js (NextAuth v5) ----
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"
# Public base URL of the app.
AUTH_URL="http://localhost:3000"

# Optional Google OAuth (only if Google login is enabled in Phase 1).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---- Email (password reset) — ยังไม่เชื่อมจริง ----
# ตอนนี้ลิงก์รีเซ็ตถูก log ใน server console (dev fallback)
# เมื่อพร้อมส่งเมลจริง ให้ตั้งค่าด้านล่าง (Resend) แล้ว restart server
# RESEND_API_KEY="re_..."
# EMAIL_FROM="HoraSard <noreply@yourdomain.com>"
# APP_BASE_URL="http://localhost:3000"

# ---- Cloudflare Turnstile (bot protection on login/register/forgot) ----
# Create at Cloudflare Dashboard → Turnstile. Site key is public (browser).
# NEXT_PUBLIC_TURNSTILE_SITE_KEY="..."
# TURNSTILE_SECRET_KEY="..."

# ---- AI providers ----
# API keys live ONLY here (server env). The database stores just the key NAME
# (secretReference), never the key value. Never expose these to the browser.
GEMINI_API_KEY=""
# Reserved for a future provider (adapter pattern). Leave empty in Phase 1.
OPENAI_API_KEY=""

# ---- Myhora scrape (chart evidence for AI) ----
# Default ON. Server scrapes myhora.com → structured tables → AI interprets only those.
# Set ENABLE_MYHORA_SCRAPE=false to force local formula-pipeline only.
# ENABLE_MYHORA_SCRAPE=true
# MYHORA_ORIGIN="https://myhora.com"
# MYHORA_SCRAPE_TIMEOUT_MS=20000

# ---- App ----
NODE_ENV="development"
# Milestone gate for the deployed demo. Leave UNSET locally to show every
# feature (dev stays ahead). On Vercel set NEXT_PUBLIC_APP_PHASE=2 so the client
# only sees Milestone 2 (auth, birth profile, Free/Pro, categories, basic admin)
# and the live AI chat + Admin AI CMS stay hidden until Milestone 3.
# NEXT_PUBLIC_APP_PHASE=2
# Comma-separated admin emails auto-promoted on seed (optional convenience).
SEED_ADMIN_EMAIL="admin@horasard.local"
SEED_ADMIN_PASSWORD="ChangeMe123!"
